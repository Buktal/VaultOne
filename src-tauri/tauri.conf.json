{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vaultone",
  "version": "1.2.0",
  "identifier": "app.vaultone",
  "build": {
    "beforeDevCommand": "yarn web:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn web:build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VaultOne",
        "width": 800,
        "height": 600,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Buktal/VaultOne/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkwQzk4OTYzMEZDRURBMwpSV1NqN2Z3d2xwZ01DYitXRW0ySVFkWkNzQi9WUi85WTVOVmFla1NBTlpZOFEwZWJ3dVQwbjl3MAo=",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}

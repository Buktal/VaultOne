{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vaultone",
  "version": "1.0.0",
  "identifier": "app.vaultone",
  "build": {
    "beforeDevCommand": "yarn web:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn web:build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VaultOne",
        "width": 800,
        "height": 600,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

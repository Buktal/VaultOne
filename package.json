{
  "name": "vaultone",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "yarn tauri:dev",
    "check": "yarn web:check && yarn rust:check",
    "test": "yarn rust:test",
    "fix": "yarn web:fix && yarn rust:fix",
    "ci": "yarn run check && yarn test && yarn web:build",
    "dist": "yarn tauri:build",
    "web:dev": "vite",
    "web:check": "biome check && tsc --noEmit",
    "web:typecheck": "tsc --noEmit",
    "web:fix": "biome check --write",
    "web:build": "tsc && vite build",
    "rust:check": "cd src-tauri && cargo fmt --check && cargo clippy --all-targets -- -D warnings",
    "rust:test": "cd src-tauri && cargo test",
    "rust:fix": "cd src-tauri && cargo fmt",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:gen": "cd src-tauri && cross-env VAULTONE_GEN_BINDINGS=1 cargo run"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/geist": "^5.3.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@reduxjs/toolkit": "^2.12.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.21",
    "lucide-react": "^1.24.0",
    "next-themes": "^0.4.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-is": "^19.2.7",
    "react-redux": "^9.3.0",
    "recharts": "^3.9.2",
    "shadcn": "^4.13.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@tailwindcss/vite": "^4.3.2",
    "@tauri-apps/cli": "^2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "cross-env": "^10.1.0",
    "tailwindcss": "^4.3.2",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
